{
  "name": "money-manager-frontend",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/shell-app",
    "dev:all": "npm run dev --workspaces --if-present",
